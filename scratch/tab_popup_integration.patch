+    // ── KeyListener ────────────────────────────────────────────────────
+    bool keyPressed (const juce::KeyPress& key, juce::Component* originatingComponent) override
+    {
+        if (originatingComponent == &codeEditor)
+        {
+            if (inlinePopup->handleKeyPress(key))
+                return true;
+                
+            // Handle normal typing and update popup filter
+            if ((key.isKeyCode(juce::KeyPress::backspaceKey) || key.isKeyCode(juce::KeyPress::deleteKey) ||
+                 key.getTextCharacter() != 0))
+            {
+                // We must process this asynchronously or after a tiny delay so the codeDocument updates first
+                juce::MessageManager::callAsync([this]() {
+                    updateInlinePopup();
+                });
+            }
+            else
+            {
+                // Arrow keys etc should probably just hide it or update position
+                juce::MessageManager::callAsync([this]() {
+                    if (!inlinePopup->isVisible()) return;
+                    updateInlinePopup();
+                });
+            }
+        }
+        return false;
+    }
+    
+    void updateInlinePopup()
+    {
+        if (!codeEditor.hasKeyboardFocus(false))
+        {
+            inlinePopup->hide();
+            return;
+        }
+        
+        auto pos = codeEditor.getCaretPos();
+        juce::String lineText = codeDocument.getLine(pos.getLineNumber());
+        int col = pos.getIndexInLine();
+        
+        // Extract word behind caret
+        int startCol = col - 1;
+        while (startCol >= 0 && (juce::CharacterFunctions::isLetterOrDigit(lineText[startCol]) || lineText[startCol] == '_'))
+        {
+            startCol--;
+        }
+        startCol++;
+        
+        juce::String prefix = lineText.substring(startCol, col);
+        
+        if (prefix.length() >= 2)
+        {
+            inlinePopup->updateFilter(prefix);
+            if (inlinePopup->isVisible())
+            {
+                // Calculate caret position on screen
+                // We don't have a direct getCaretPositionOnScreen(), but we can estimate
+                // or use codeEditor.getTextBounds() if available.
+                // For now, let's just place it at top-left of editor + some padding
+                // Actually, JUCE CodeEditorComponent has `getTextBounds` or we can approximate using line height.
+                // line height is font height.
+                // This is a naive approximation for now.
+                inlinePopup->showAt(codeEditor.getBounds().getTopLeft().translated(10, 10)); // TODO: accurate pos
+            }
+        }
+        else
+        {
+            inlinePopup->hide();
+        }
+    }
